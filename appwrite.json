    "projectName": "ghostssh",
    "functions": [
        {
            "$id": "cron-scanner",
            "name": "Job Scanner Cron",
            "runtime": "node-18.0",
            "execute": [],
            "events": [],
            "schedule": "0 */6 * * *",
            "timeout": 300,
            "enabled": true,
            "logging": true,
            "entrypoint": "src/main.ts",
            "commands": "npm install && npm run build",
            "ignore": [
                "node_modules",
                ".npm"
            ],
            "path": "functions/cron-scanner"
        }
    ],
    "endpoints": {
        "functions": "https://sfo.cloud.appwrite.io/v1"
    }
}