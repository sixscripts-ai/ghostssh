NODE_ENV=development
PORT=8080

# ─── Primary LLM: Minimax M2.7 ───────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# ─── Fallback providers ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

DEFAULT_PROVIDER=minimax
FALLBACK_PROVIDER=anthropic

# ─── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
USER_AGENT=ghostssh/1.0

# ─── Mem0 Cloud ───────────────────────────────────────────────────────────────
MEM0_API_KEY=

# ─── Jina AI ──────────────────────────────────────────────────────────────────
JINA_API_KEY=

# ─── Appwrite ─────────────────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=sfo-69be176f00077d92699d
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=ghostssh
APPWRITE_JOBS_COLLECTION_ID=jobs
APPWRITE_PROFILES_COLLECTION_ID=profiles
APPWRITE_APPLICATIONS_COLLECTION_ID=applications

# ─── Cron auth ────────────────────────────────────────────────────────────────
CRON_SECRET=

# Auto-apply settings (Applier agent)
AUTO_APPLY_ENABLED=false
AUTO_APPLY_MIN_SCORE=85
AUTO_APPLY_MAX_PER_DAY=5
